{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Semantic search vs hybrid search\n",
    "\n",
    "Here we ingest the three sample documents, run a few queries, and compare pure semantic search against hybrid (BM25 + semantic). You'll see how hybrid catches exact-keyword matches that semantic search can miss, and how semantic handles paraphrases that keyword search would skip.\n",
    "\n",
    "Make sure you've installed the requirements first (`pip install -r requirements.txt`)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys, os\n",
    "sys.path.insert(0, os.path.abspath('..'))\n",
    "\n",
    "from src.embeddings.generator import EmbeddingGenerator\n",
    "from src.storage.chroma_store import ChromaVectorStore\n",
    "from src.retrieval.chunker import DocumentChunker\n",
    "from src.search.semantic_search import SemanticSearch\n",
    "from src.search.hybrid_search import HybridSearch\n",
    "from pathlib import Path\n",
    "\n",
    "gen = EmbeddingGenerator('fast')\n",
    "store = ChromaVectorStore(persist_dir='../chroma_data', collection_name='notebook_demo')\n",
    "chunker = DocumentChunker(chunk_size=256, overlap=32)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Ingest the sample documents\n",
    "doc_dir = Path('../data/sample_docs')\n",
    "all_chunks = []\n",
    "for f in doc_dir.glob('*.txt'):\n",
    "    text = f.read_text(encoding='utf-8')\n",
    "    chunks = chunker.chunk(text, source=f.stem)\n",
    "    all_chunks.extend(chunks)\n",
    "\n",
    "print(f'Total chunks: {len(all_chunks)}')\n",
    "\n",
    "ids = [c['id'] for c in all_chunks]\n",
    "texts = [c['text'] for c in all_chunks]\n",
    "metas = [c['metadata'] for c in all_chunks]\n",
    "embeddings = gen.embed_batch(texts)\n",
    "store.upsert(ids, embeddings, texts, metas)\n",
    "print('Ingested successfully.')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Semantic search\n",
    "sem = SemanticSearch(store, gen)\n",
    "query = 'how does attention work in transformers'\n",
    "results = sem.search(query, n_results=3)\n",
    "\n",
    "print(f'Query: \"{query}\"\\n')\n",
    "for r in results:\n",
    "    print(f\"  [{r['score']:.3f}] {r['id']}\")\n",
    "    print(f\"  {r['text'][:200]}...\\n\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Hybrid search — same query, compare results\n",
    "hyb = HybridSearch(store, gen, alpha=0.6)\n",
    "h_results = hyb.search(query, collection='notebook_demo', n_results=3)\n",
    "\n",
    "print(f'Hybrid results for: \"{query}\"\\n')\n",
    "for r in h_results:\n",
    "    print(f\"  [combined {r['score']:.3f} | bm25 {r['bm25_score']:.3f} | sem {r['semantic_score']:.3f}] {r['id']}\")\n",
    "    print(f\"  {r['text'][:200]}...\\n\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Exact keyword query — BM25 should dominate\n",
    "kw_query = 'BM25 Okapi keyword scoring'\n",
    "sem_kw = sem.search(kw_query, n_results=3)\n",
    "hyb_kw = HybridSearch(store, gen, alpha=0.2).search(kw_query, collection='notebook_demo', n_results=3)\n",
    "\n",
    "print('Semantic top result:', sem_kw[0]['id'])\n",
    "print('Hybrid top result (alpha=0.2, more keyword weight):', hyb_kw[0]['id'])"
   ]
  }
 ],
